<mxfile host="app.diagrams.net">
  <diagram name="Architecture Big Data">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Titre -->
        <mxCell id="title" value="ARCHITECTURE BIG DATA – ENTREPRISE TÉLÉCOM FICTIVE GUINÉENNE"
        style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0B1F5E;fontColor=#FFFFFF;fontSize=18;"
        vertex="1" parent="1">
          <mxGeometry x="120" y="20" width="800" height="50" as="geometry"/>
        </mxCell>

        <!-- Sources -->
        <mxCell id="sources"
        value="1. SOURCES DE DONNÉES&#xa;&#xa;• CDR → CSV&#xa;• Mobile Money → JSON&#xa;• Réseaux sociaux → API JSON&#xa;• Antennes réseau → XML&#xa;• Logs Web/App → TXT"
        style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4A90E2;fontColor=#FFFFFF;fontSize=14;"
        vertex="1" parent="1">
          <mxGeometry x="180" y="100" width="650" height="120" as="geometry"/>
        </mxCell>

        <!-- Ingestion -->
        <mxCell id="ingestion"
        value="2. COUCHE D'INGESTION&#xa;&#xa;Apache Kafka&#xa;Apache NiFi"
        style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1ABC9C;fontColor=#FFFFFF;fontSize=14;"
        vertex="1" parent="1">
          <mxGeometry x="180" y="270" width="650" height="90" as="geometry"/>
        </mxCell>

        <!-- Stockage -->
        <mxCell id="storage"
        value="3. STOCKAGE&#xa;&#xa;Data Lake : Hadoop HDFS&#xa;Data Warehouse : PostgreSQL"
        style="rounded=1;whiteSpace=wrap;html=1;fillColor=#27AE60;fontColor=#FFFFFF;fontSize=14;"
        vertex="1" parent="1">
          <mxGeometry x="180" y="410" width="650" height="90" as="geometry"/>
        </mxCell>

        <!-- Traitement -->
        <mxCell id="processing"
        value="4. TRAITEMENT&#xa;&#xa;Batch : Apache Spark&#xa;Temps réel : Kafka + Spark Streaming"
        style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F39C12;fontColor=#FFFFFF;fontSize=14;"
        vertex="1" parent="1">
          <mxGeometry x="180" y="550" width="650" height="90" as="geometry"/>
        </mxCell>

        <!-- Modèles -->
        <mxCell id="models"
        value="5. MODÈLES ET RÉSULTATS&#xa;&#xa;Random Forest&#xa;K-Means&#xa;Isolation Forest"
        style="rounded=1;whiteSpace=wrap;html=1;fillColor=#8E44AD;fontColor=#FFFFFF;fontSize=14;"
        vertex="1" parent="1">
          <mxGeometry x="180" y="690" width="650" height="90" as="geometry"/>
        </mxCell>

        <!-- Présentation -->
        <mxCell id="presentation"
        value="6. PRÉSENTATION&#xa;&#xa;Power BI&#xa;Tableau&#xa;Grafana&#xa;Jupyter Notebook"
        style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E74C3C;fontColor=#FFFFFF;fontSize=14;"
        vertex="1" parent="1">
          <mxGeometry x="180" y="830" width="650" height="90" as="geometry"/>
        </mxCell>

        <!-- Flèches -->
        <mxCell id="e1" edge="1" parent="1" source="sources" target="ingestion">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e2" edge="1" parent="1" source="ingestion" target="storage">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e3" edge="1" parent="1" source="storage" target="processing">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e4" edge="1" parent="1" source="processing" target="models">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e5" edge="1" parent="1" source="models" target="presentation">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>